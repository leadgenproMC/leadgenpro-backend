# CONFIGURACIÓN EMAIL REAL - LEADGENPRO
# ======================================

# Servidor SMTP (Gmail recomendado)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# Credenciales email
SMTP_USER=tu-email@gmail.com
SMTP_PASSWORD=tu-app-password
FROM_EMAIL=tu-email@gmail.com

# Alternativa: SendGrid
# SMTP_SERVER=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASSWORD=SG.xxxxx
# FROM_EMAIL=noreply@leadgenpro.com

# Base de datos (si se usa)
SUPABASE_URL=your-supabase-url
SUPABASE_SECRET_KEY=your-supabase-key

# CORS
CORS_ALLOW_ORIGINS=https://leadgenpro-frontend.netlify.app,http://localhost:3000

# Debug
PYTHONUNBUFFERED=1
